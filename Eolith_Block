// ═══════ HISTORY ════════════════════════════════════════════
function saveHistory(results,totalQty,maxHrs){
  const hist=JSON.parse(localStorage.getItem('eolith_hist')||'[]');
  hist.unshift({ts:new Date().toLocaleString('en-IN'),totalQty,maxHrs:Math.round(maxHrs*10)/10,
    orders:results.map(r=>({size:r.size,bc:r.bc,qty:r.qty,hAvg:Math.round(r.hAvg*10)/10}))});
  if(hist.length>5)hist.splice(5);
  localStorage.setItem('eolith_hist',JSON.stringify(hist));
}
function renderHistory(){
  const hist=JSON.parse(localStorage.getItem('eolith_hist')||'[]');
  const el=document.getElementById('histList');
  if(!el)return;
  if(!hist.length){el.innerHTML='<p style="font-size:.75rem;color:var(--stone);">Koi history nahi hai.</p>';return;}
  el.innerHTML=hist.map((h,i)=>`
    <div class="hist-item">
      <div class="hist-hdr" onclick="toggleHist(${i})">
        <div class="hist-title">📋 ${h.ts} — ${h.orders.length} Orders · ${(h.totalQty||0).toLocaleString()} Sq Ft</div>
        <div class="hist-time">⏱ ${h.maxHrs}h</div>
      </div>
      <div class="hist-body" id="hb_${i}">
        ${h.orders.map((o,j)=>`<div class="hr"><strong>${j+1}.</strong> ${o.bc} · <strong>${o.size}mm</strong> · ${(o.qty||0).toLocaleString()} SqFt · ${o.hAvg}h</div>`).join('')}
      </div>
    </div>`).join('');
}
function toggleHist(i){const el=document.getElementById('hb_'+i);if(el)el.classList.toggle('open');}
function clearHistory(){localStorage.removeItem('eolith_hist');renderHistory();}

// ═══════ TOAST ═══════════════════════════════════════════════
function toast(msg,type){
  const w=document.getElementById('toastWrap');
  const d=document.createElement('div');
  d.className='toast'+(type?' '+type:'');
  d.textContent=msg; w.appendChild(d);
  requestAnimationFrame(()=>d.classList.add('show'));
  setTimeout(()=>{d.classList.remove('show');setTimeout(()=>d.remove(),350);},3500);
}

