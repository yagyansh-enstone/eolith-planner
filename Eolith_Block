      document.getElementById('testResult').innerHTML=`<span style="color:var(--green);">✅ Sheet Connected! Tabs: ${d.sheets.join(', ')}</span>`;
      toast('Sheet connected! ✅','g');
    } else {
      document.getElementById('testResult').innerHTML=`<span style="color:var(--red);">❌ Error: ${d.msg}</span>`;
    }
  }catch(e){
    document.getElementById('testResult').innerHTML=`<span style="color:var(--red);">❌ Failed: ${e.message}</span>`;
  }
}
