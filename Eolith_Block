// ═══════ CALCULATE ════════════════════════════════════════════
function calculate(){
  const rows=document.querySelectorAll('.plan-row');
  if(!rows.length){alert('Pehle rows add karein.');return;}
  const orders=[];
  rows.forEach(row=>{
    const id=row.id.replace('row_','');
    const sz=document.getElementById('sz_'+id);
    if(!sz)return;
    const mn=Number(document.getElementById('mn_'+id).value);
    const mx=Number(document.getElementById('mx_'+id).value);
    const qty=Number(document.getElementById('qty_'+id).value);
    if(!qty||qty<=0)return;
    orders.push({id,size:sz.value,bc:document.getElementById('bc_'+id).value,qty,min:mn,max:mx,avg:(mn+mx)/2});
  });
  const fmtH=h=>{
    if(!isFinite(h)||h<=0)return '0h';
    const hh=Math.floor(h),mm=Math.round((h-hh)*60);
    const d=Math.floor(hh/24),rh=hh%24;
    return d>0?`${d}d ${rh}h${mm?' '+mm+'m':''}`:`${hh}h${mm?' '+mm+'m':''}`;
  };
  const results=orders.map(o=>{
    const hAvg=o.avg>0?(o.qty/o.avg)*24:0;
    const hBest=o.max>0?(o.qty/o.max)*24:0;
    const hWorst=o.min>0?(o.qty/o.min)*24:0;
    return{...o,hAvg,hBest,hWorst,dayProd:Math.round(o.avg/24*12),nightProd:Math.round(o.avg/24*12)};
  });
  lastResults=results;
  const totalQty=orders.reduce((s,o)=>s+o.qty,0);
  const maxHrs=results.reduce((m,r)=>r.hAvg>m?r.hAvg:m,0);
  const totalAvg24=orders.reduce((s,o)=>s+o.avg,0);
  const sCls=maxHrs<=12?'g':maxHrs<=24?'a':'r';

  document.getElementById('sumBar').innerHTML=`
    <div class="stat"><div class="v ${sCls}">${fmtH(maxHrs)}</div><div class="lbl">Max Time</div></div>
    <div class="stat"><div class="v">${totalQty.toLocaleString()}</div><div class="lbl">Total Sq Ft</div></div>
    <div class="stat"><div class="v">${results.length}</div><div class="lbl">Active BCs</div></div>
    <div class="stat"><div class="v">${results.filter(r=>r.hAvg<=12).length}/${results.length}</div><div class="lbl">1 Shift Mein</div></div>
    <div class="stat"><div class="v">${Math.round(totalAvg24).toLocaleString()}</div><div class="lbl">Capacity/24hr</div></div>
    <div class="stat"><div class="v">${new Date().toLocaleDateString('en-IN')}</div><div class="lbl">Date</div></div>`;

  const tD=results.reduce((s,r)=>s+r.dayProd,0);
  const tN=results.reduce((s,r)=>s+r.nightProd,0);
  document.getElementById('shiftBanner').innerHTML=`
    <div class="sc day"><div style="font-size:1.5rem">☀️</div><div>
      <div class="sh-lbl">Day Shift</div><div class="sh-t">8:00 AM – 8:00 PM (12 Hr)</div>
      <div class="sh-p">~${tD.toLocaleString()} Sq Ft</div></div></div>
    <div class="sc night"><div style="font-size:1.5rem">🌙</div><div>
      <div class="sh-lbl">Night Shift</div><div class="sh-t">8:00 PM – 8:00 AM (12 Hr)</div>
      <div class="sh-p">~${tN.toLocaleString()} Sq Ft</div></div></div>`;

  // Prediction
  let pCls,pTitle,pBody;
  if(maxHrs<=12){pCls='predict-ok';pTitle='✅ 1 Shift Mein Complete Hoga';pBody=`Sabse lamba order <strong>${fmtH(maxHrs)}</strong> mein complete — aaj dispatch possible!`;}
  else if(maxHrs<=24){pCls='predict-warn';pTitle='⚠ Dono Shifts Lagegi — Kal Dispatch';pBody=`<strong>${fmtH(maxHrs)}</strong> chahiye. Day + Night dono shifts mein production karo.`;}
  else{
    const d=Math.ceil(maxHrs/24);
    pCls='predict-danger';pTitle=`🔴 Delay — ${d} Din Chahiye`;
    pBody=`Current capacity par <strong>${fmtH(maxHrs)}</strong>.<br>Options: Extra BC lagao • Quantity reduce karo • Dispatch date badhao`;
  }
  document.getElementById('predictBox').innerHTML=`<div class="${pCls} predict-box"><div class="predict-title">${pTitle}</div><div class="predict-body">${pBody}</div></div>`;

  // Table
  const tbody=document.getElementById('multiBody');
  tbody.innerHTML='';
  results.forEach((r,i)=>{
    const pct=maxHrs>0?Math.round((r.hAvg/maxHrs)*100):0;
    const pc=r.hAvg<=12?'pill-g':r.hAvg<=24?'pill-a':'pill-r';
    tbody.innerHTML+=`<tr>
      <td style="color:var(--stone);font-weight:700;">${i+1}</td>
      <td><span class="tag">${r.size}mm</span></td>
      <td><strong>${r.bc}</strong>${BC_DATA[r.bc].wastage?'<br><span style="font-size:.6rem;color:var(--amber);">♻</span>':''}</td>
      <td><strong>${r.qty.toLocaleString()}</strong></td>
      <td>${r.min.toLocaleString()}–${r.max.toLocaleString()}<br><span style="font-size:.62rem;color:var(--stone);">avg ${Math.round(r.avg).toLocaleString()}</span></td>
      <td><span class="pill ${pc}">${fmtH(r.hAvg)}</span><br><span style="font-size:.6rem;color:var(--stone);">${fmtH(r.hBest)}–${fmtH(r.hWorst)}</span></td>
      <td>~${r.dayProd.toLocaleString()}</td>
      <td>~${r.nightProd.toLocaleString()}</td>
      <td><div class="bar-bg"><div class="bar-fill" style="width:${pct}%;background:${r.hAvg<=12?'#22c55e':r.hAvg<=24?'#f59e0b':'#ef4444'}"></div></div></td>
    </tr>`;
  });

  const lr=results.reduce((a,b)=>a.hAvg>b.hAvg?a:b);
  const gpCls=maxHrs<=12?'background:#dcfce7;color:#166534':maxHrs<=24?'background:#fef3c7;color:#92400e':'background:#fee2e2;color:#991b1b';
  document.getElementById('grandTotal').innerHTML=`
    <div><div class="gt-l">Total</div><div class="gt-v">${totalQty.toLocaleString()} Sq Ft</div></div>
    <div><div class="gt-l">Longest BC</div><div class="gt-v" style="font-size:.9rem;">${lr.bc}·${lr.size}mm</div></div>
    <div><div class="gt-l">Max Time</div><div class="gt-v">${fmtH(maxHrs)}</div></div>
    <div><span class="gtpill" style="${gpCls}">${maxHrs<=12?'✓ 1 Shift':maxHrs<=24?'~ 1 Din':'⚠ 1+ Din'}</span></div>`;

  buildWAMsg(results,totalQty,maxHrs,fmtH);
  document.getElementById('resultWrap').classList.add('show');
  saveHistory(results,totalQty,maxHrs);
}

function buildWAMsg(results,totalQty,maxHrs,fmtH){
  const dt=new Date().toLocaleDateString('en-IN');
  const tm=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  let msg=`🏭 *${CFG.company.toUpperCase()}*\n📋 Production Planning Report\n📅 ${dt} | ${tm}\n👤 MIS: ${CFG.mis}\n${'─'.repeat(28)}\n\n`;
  results.forEach((r,i)=>{
    msg+=`${i+1}. *${r.bc}* → ${r.size}mm · ${r.qty.toLocaleString()} Sq Ft\n`;
    msg+=`   ⏱ ${fmtH(r.hAvg)} | 📊 ${r.min}–${r.max} Sq Ft/24hr\n`;
    msg+=`   ☀️ Day ~${r.dayProd.toLocaleString()} | 🌙 Night ~${r.nightProd.toLocaleString()} Sq Ft\n\n`;
  });
  msg+=`${'─'.repeat(28)}\n📊 *Total: ${totalQty.toLocaleString()} Sq Ft*\n⏰ *Max Time: ${fmtH(maxHrs)}*\n`;
  const pred=maxHrs<=12?'✅ 1 Shift mein':maxHrs<=24?'⚠ Dono Shifts':'🔴 1 Din Se Zyada';
  msg+=`🔮 *${pred}*\n\n_Eolith Production Planner v4_`;
  document.getElementById('waPreview').textContent=msg;
  return msg;
}

// ═══════ SHEET SAVE ═══════════════════════════════════════════
async function saveToSheet(){
  if(!lastResults.length){toast('Pehle calculate karein!','r');return;}
  if(!CFG.scriptUrl||CFG.scriptUrl.includes('PLACEHOLDER')){
    toast('Apps Script URL set nahi hai! Code update karein.','r');return;
  }
  toast('Google Sheet mein save ho raha hai...','');
  const dt=new Date().toLocaleDateString('en-IN');
  const tm=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  const planId='PLN-'+Date.now().toString().slice(-6);
  const rows=lastResults.map(r=>[
    dt,tm,planId,r.size,r.bc,r.qty,r.min,r.max,
    Math.round(r.hAvg*10)/10,r.dayProd,r.nightProd,
    r.hAvg<=12?'1 Shift':r.hAvg<=24?'2 Shifts':'Delay Risk',CFG.mis
  ]);
  try{
    const res=await fetch(CFG.scriptUrl,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({action:'saveProduction',rows})});
    const d=await res.json();
    if(d.status==='ok') toast(`✅ Sheet mein ${d.saved} rows save ho gayi!`,'g');
    else toast('❌ Error: '+d.msg,'r');
  }catch(e){toast('❌ Connection error — Apps Script URL check karein.','r');}
}

