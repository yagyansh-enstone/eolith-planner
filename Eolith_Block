async function sendWhatsApp(){
  const wa=getWA();
  if(!wa.num&&!wa.group){toast('Settings mein WhatsApp number ya Group ID daalen!','r');switchTab('settings');return;}
  const msg=document.getElementById('waPreview').textContent||'Eolith Production Update';
  await sendWAMsg(msg);
}
async function sendWAMsg(msg){
  const wa=getWA();
  const url=`https://api.green-api.com/waInstance${CFG.waId}/sendMessage/${CFG.waToken}`;
  const targets=[];
  if(wa.num) targets.push(wa.num.replace(/\D/g,'')+'@c.us');
  if(wa.group) targets.push(wa.group);
  if(!targets.length){toast('WhatsApp number ya group ID settings mein daalen!','r');return;}
  toast('WhatsApp bhej raha hai...','');
  try{
    for(const chatId of targets){
      await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({chatId,message:msg})});
    }
    toast('✅ WhatsApp message bhej diya!','g');
  }catch(e){toast('❌ WhatsApp error: '+e.message,'r');}
}

// ═══════ DISPATCH MONTHLY STATUS ══════════════════════════════
let dispatchStatusData=[];

async function loadDispatchStatus(){
  if(!CFG.scriptUrl||CFG.scriptUrl.includes('PLACEHOLDER')){
    document.getElementById('dispatchStatusWrap').innerHTML=
      '<div class="warn-box">⚠ Apps Script URL set nahi hai. HTML code mein update karein.</div>';
    return;
  }
  document.getElementById('dispatchStatusWrap').innerHTML='<div class="warn-box">⏳ Sheet se data load ho raha hai...</div>';
  try{
    const res=await fetch(CFG.scriptUrl+'?action=getDispatchStatus');
    const d=await res.json();
    if(d.status==='ok'&&d.data&&d.data.length>1){
      dispatchStatusData=d.data;
      renderDispatchStatusTable(d.data);
    } else {
      document.getElementById('dispatchStatusWrap').innerHTML=
        '<div class="warn-box">⚠ Sheet mein koi data nahi hai ya "Dispatch Monthly Planning Status" tab nahi bana. "+ Add Entry" se entry add karein.</div>';
    }
  }catch(e){
    document.getElementById('dispatchStatusWrap').innerHTML=
      `<div class="warn-box">❌ Sheet se connect nahi ho saka. Apps Script URL check karein.<br><small>${e.message}</small></div>`;
  }
}

function renderDispatchStatusTable(data){
  if(!data||data.length<2){
    document.getElementById('dispatchStatusWrap').innerHTML='<div class="warn-box">Koi data nahi hai.</div>';
    return;
  }
  const headers=data[0];
  const rows=data.slice(1);

  // Status columns (8=ProdStatus, 9=PackStatus, 10=DispStatus — 0-indexed from headers)
  const prodIdx=headers.indexOf('Production Status');
  const packIdx=headers.indexOf('Packing Status');
  const dispIdx=headers.indexOf('Dispatch Status');

  let html=`<div style="overflow-x:auto;"><table class="ds-tbl"><thead><tr>
    <th>#</th>${headers.map(h=>`<th>${h}</th>`).join('')}<th>Update</th>
  </tr></thead><tbody>`;

  rows.forEach((row,ri)=>{
    const rowIdx=ri+2; // 1-based with header
    const sbMap={
      'Done':'sb-done','Not Done':'sb-notdone','In Progress':'sb-partial',
      'Partial':'sb-partial','Dispatched':'sb-done','Pending':'sb-pending',
      'Delayed':'sb-notdone','Ready':'sb-done'
    };
    html+=`<tr>`;
    html+=`<td style="color:var(--stone);font-weight:700;">${ri+1}</td>`;
    row.forEach((cell,ci)=>{
      const isProdStat=headers[ci]==='Production Status';
      const isPackStat=headers[ci]==='Packing Status';
      const isDispStat=headers[ci]==='Dispatch Status';
      if(isProdStat||isPackStat||isDispStat){
        const opts=isProdStat?
          ['Done','Not Done','In Progress','Partial']:
          isPackStat?['Done','Not Done','In Progress']:
          ['Dispatched','Pending','Delayed','Ready'];
        html+=`<td><select class="status-sel" onchange="updateStatus(${rowIdx},${ci+1},this.value)">
          ${opts.map(o=>`<option ${cell===o?'selected':''}>${o}</option>`).join('')}
        </select></td>`;
      } else {
        const sbCls=sbMap[cell]||'';
        html+=`<td>${sbCls?`<span class="sb ${sbCls}">${cell}</span>`:cell||'—'}</td>`;
      }
    });
    html+=`<td><button onclick="deleteStatusRow(${rowIdx})" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:.9rem;" title="Delete">🗑</button></td>`;
    html+=`</tr>`;
  });
  html+=`</tbody></table></div>`;
  document.getElementById('dispatchStatusWrap').innerHTML=html;
}

async function updateStatus(rowIndex, colIndex, value){
  if(!CFG.scriptUrl||CFG.scriptUrl.includes('PLACEHOLDER')) return;
  try{
    const res=await fetch(CFG.scriptUrl,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({action:'updateDispatchStatus',updateType:'updateStatus',
        rowIndex, colUpdates:{[colIndex]:value}})});
    const d=await res.json();
    if(d.status==='ok') toast('✅ Status update ho gaya!','g');
    else toast('❌ Error: '+d.msg,'r');
  }catch(e){toast('❌ Update failed: '+e.message,'r');}
}

async function deleteStatusRow(rowIndex){
  if(!confirm('Yeh row delete karna chahte hain?')) return;
  try{
    const res=await fetch(CFG.scriptUrl,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({action:'updateDispatchStatus',updateType:'deleteRow',rowIndex})});
    const d=await res.json();
    if(d.status==='ok'){toast('✅ Row delete ho gayi!','g');loadDispatchStatus();}
    else toast('❌ Error: '+d.msg,'r');
  }catch(e){toast('❌ Delete failed: '+e.message,'r');}
}

